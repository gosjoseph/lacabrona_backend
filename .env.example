# MongoDB
MONGO_URL=mongodb://localhost:27017
MONGO_DB=lacabrona

# CORS (comma-separated list of allowed frontend origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:4173,https://localhost:5173

# SuperTokens core (use the docker-compose service hostname in dev,
# the Coolify-hosted core URL in prod)
SUPERTOKENS_CORE_URL=http://supertokens:3567
# IMPORTANT: the API key MUST NOT contain underscores — the SuperTokens
# fallback parser splits on them and silently rejects the key.
SUPERTOKENS_API_KEY=local-dev-api-key-change-me
SUPERTOKENS_APP_NAME=La Cabrona

# Public URLs used by SuperTokens app_info
API_DOMAIN=https://localhost:8443
APP_URL=https://localhost:5173

# Google OAuth (used by SuperTokens ThirdParty recipe)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# App
ENVIRONMENT=development
